{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nexus-gui",
  "version": "5.2.7",
  "identifier": "com.aurel.nexus-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1100,
        "height": 720,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "appimage": {
        "excludeLibs": [
          "libwayland-client.so.0",
          "libwayland-server.so.0",
          "libwayland-egl.so.1",
          "libwayland-cursor.so.0",
          "libEGL.so.1",
          "libGL.so.1",
          "libgbm.so.1",
          "libepoxy.so.0",
          "libxcb.so.1",
          "libX11.so.6"
        ]
      }
    },
    "externalBin": [
      "bin/nexus-daemon",
      "bin/ffmpeg",
      "bin/rclone"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/client_secret.json"
    ]
  }
}
